# =========================
# Secrets / credentials
# =========================
.env
.env.*
*.key
*.pem
secrets/
credentials/
token*
*api_key*
*API_KEY*

# =========================
# Node / frontend
# =========================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# =========================
# Python
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
backend/.venv/
backend/venv/
backend/__pycache__/
backend/app/__pycache__/
backend/scripts/__pycache__/

# =========================
# Build / cache / logs
# =========================
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.log
logs/
tmp/
temp/

# =========================
# OS / editor
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =========================
# Large generated archives
# =========================
*.zip
*.7z
*.rar
*.tar
*.gz

# =========================
# Large local datasets
# 기본은 DB 제외. 필요하면 Git LFS로 별도 처리.
# =========================
*.db
*.sqlite
*.sqlite3

# =========================
# Optional local outputs
# =========================
exports/
downloads/
local_backups/

